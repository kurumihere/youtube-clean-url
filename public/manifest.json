{
  "manifest_version": 3,
  "name": "YouTube Clean URL",
  "short_name": "YT Clean URL",
  "description": "Copy clean YouTube URLs with Ctrl+Shift+Y.",
  "version": "1.0.0",
  "minimum_chrome_version": "102",
  "permissions": ["tabs", "scripting"],
  "host_permissions": [
    "https://www.youtube.com/*",
    "https://youtube.com/*",
    "https://m.youtube.com/*",
    "https://youtu.be/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "action": {
    "default_title": "Copy clean YouTube URL"
  },
  "commands": {
    "copy-clean-youtube-url": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Copy clean YouTube URL"
    }
  }
}
