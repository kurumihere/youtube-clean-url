{
  "manifest_version": 3,
  "name": "YouTube Clean URL",
  "short_name": "YT Clean URL",
  "description": "Copy clean YouTube URLs.",
  "version": "1.0.0",
  "permissions": ["tabs", "scripting", "clipboardWrite"],
  "host_permissions": [
    "https://youtube.com/*",
    "https://*.youtube.com/*",
    "https://youtu.be/*"
  ],
  "action": {
    "default_title": "Copy clean YouTube URL"
  },
  "commands": {
    "copy-clean-youtube-url": {
      "suggested_key": {
        "default": "Ctrl+Shift+Y"
      },
      "description": "Copy clean YouTube URL"
    },
    "copy-clean-youtube-url-with-timestamp": {
      "suggested_key": {
        "default": "Ctrl+Shift+U"
      },
      "description": "Copy clean YouTube URL with timestamp"
    }
  }
}
