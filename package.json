{
  "name": "youtube-clean-url",
  "version": "1.0.0",
  "description": "Copy clean YouTube URLs (Ctrl+Shift+Y).",
  "private": true,
  "type": "module",
  "scripts": {
    "clean": "rimraf dist",
    "copy": "cp -r public/* dist/",
    "typecheck": "tsc --noEmit",
    "build": "npm run clean && tsc && npm run copy"
  },
  "devDependencies": {
    "@types/chrome": "^0.1.42",
    "rimraf": "^6.1.3",
    "typescript": "^6.0.3"
  }
}
